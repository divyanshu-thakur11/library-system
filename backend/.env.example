# Server
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# Database (PostgreSQL) - use ONE of the two options below

# Option A: single connection URL. If your password contains any of
# @ : / ? # % & you MUST percent-encode it (e.g. p@ss -> p%40ss) or the
# connection will silently fail with a "SASL ... password must be a
# string" error. See README for the encoding table.
DATABASE_URL=postgres://user:password@localhost:5432/library_system

# Option B: discrete fields - no encoding needed, easiest with odd
# passwords. If PGHOST is set, this takes priority over DATABASE_URL.
# PGHOST=localhost
# PGPORT=5432
# PGUSER=user
# PGPASSWORD=your-actual-password
# PGDATABASE=library_system

# Set to "true" when connecting to a cloud DB that requires SSL (e.g. Render, Supabase, Neon)
DATABASE_SSL=false

# Auth
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
COOKIE_SECURE=false
